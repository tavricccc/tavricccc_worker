# ==============================================================================
# Cloudflare Worker Environment Variables & Secrets Configuration (Template)
# Rename this file to .env and fill in the values. Do NOT commit .env to Git!
# ==============================================================================

# 1. Non-Sensitive Vars (Used by scripts / wrangler.toml replacement)
GITHUB_CLIENT_ID=PLACEHOLDER_GITHUB_CLIENT_ID
# R2_PUBLIC_URL=https://your-custom-r2-domain.com  # Optional: if you bound a domain to your R2 bucket.

# 2. Worker Secret Variables (Uploaded via upload_secrets.bat / GitHub Actions)
GITHUB_CLIENT_SECRET=your_github_client_secret
RESEND_API_KEY=re_your_resend_api_key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_turnstile_secret_key
CONTACT_TO_EMAIL=your_inbox_email@example.com
ADMIN_EMAILS=your_admin_email@example.com,another_admin@example.com
MODERATION_SECRET=any_long_random_string_to_sign_moderation_links
